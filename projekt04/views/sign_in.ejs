<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/css/core.css">
    <link rel="stylesheet" href="/css/form.css">
    <link rel="stylesheet" href="/css/nav.css">
    <title><%= title %></title>
</head>
<body>
    <%- include("header.ejs") %>

    <p id="problem_msg"><%= creation_msg %></p>

    <form action="/account_sign_in" method="post" id="form">
        <input type="text" name="login" placeholder="Please enter the username" minlength="3" maxlength="200" required>
        <input type="password" name="password" placeholder="Please enter the password" required>
        <input type="submit" value="Log In">
    </form>
    
</body>
</html>